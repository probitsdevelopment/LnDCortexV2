{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "packages/twenty-server/Dockerfile"
  },
  "deploy": {
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 60,
    "numReplicas": 1
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "PORT": "3000",
        "SERVER_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
        "FRONT_BASE_URL": "https://${{twenty-front.RAILWAY_PUBLIC_DOMAIN}}",
        "DATABASE_URL": "${{Postgres.DATABASE_URL}}",
        "REDIS_URL": "${{Redis.REDIS_URL}}",
        "ACCESS_TOKEN_SECRET": "${{RAILWAY_PROJECT_ID}}",
        "LOGIN_TOKEN_SECRET": "${{RAILWAY_PROJECT_ID}}",
        "REFRESH_TOKEN_SECRET": "${{RAILWAY_PROJECT_ID}}",
        "FILE_TOKEN_SECRET": "${{RAILWAY_PROJECT_ID}}",
        "SIGN_IN_PREFILLED": "false",
        "STORAGE_TYPE": "local",
        "MESSAGE_QUEUE_TYPE": "bull-mq",
        "LOGGER_DRIVER": "console"
      }
    }
  }
}