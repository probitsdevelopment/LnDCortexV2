{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "packages/twenty-worker/Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "DATABASE_URL": "${{Postgres.DATABASE_URL}}",
        "REDIS_URL": "${{Redis.REDIS_URL}}",
        "SERVER_URL": "https://${{twenty-server.RAILWAY_PUBLIC_DOMAIN}}",
        "ACCESS_TOKEN_SECRET": "${{RAILWAY_PROJECT_ID}}",
        "LOGIN_TOKEN_SECRET": "${{RAILWAY_PROJECT_ID}}",
        "REFRESH_TOKEN_SECRET": "${{RAILWAY_PROJECT_ID}}",
        "FILE_TOKEN_SECRET": "${{RAILWAY_PROJECT_ID}}",
        "MESSAGE_QUEUE_TYPE": "bull-mq",
        "LOGGER_DRIVER": "console"
      }
    }
  }
}