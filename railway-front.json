{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "packages/twenty-front/Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "REACT_APP_SERVER_BASE_URL": "${{twenty-server.RAILWAY_PUBLIC_DOMAIN}}",
        "PORT": "80"
      }
    }
  }
}