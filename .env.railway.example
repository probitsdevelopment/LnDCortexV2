# Railway Environment Variables Template
# Copy this file to configure your Railway services

#################
# BACKEND SERVICE
#################

# Database URLs (automatically provided by Railway)
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# JWT Secrets (generate random strings)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
ACCESS_TOKEN_SECRET=your-access-token-secret-minimum-32-characters  
LOGIN_TOKEN_SECRET=your-login-token-secret-minimum-32-characters
REFRESH_TOKEN_SECRET=your-refresh-token-secret-minimum-32-characters

# Application URLs
FRONT_BASE_URL=https://your-frontend-service.railway.app
SERVER_URL=https://your-backend-service.railway.app

# Email Configuration (optional)
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_SYSTEM_ADDRESS=system@yourdomain.com

# Storage Configuration
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=.local-storage

# Feature Flags
SIGN_IN_PREFILLED=true
IS_SIGN_UP_DISABLED=false

# NX Configuration
NIXPACKS_NX_APP_NAME=twenty-server
NODE_ENV=development

#################
# FRONTEND SERVICE  
#################

# Backend URL
REACT_APP_SERVER_BASE_URL=https://your-backend-service.railway.app

# Build Configuration
GENERATE_SOURCEMAP=false

# NX Configuration  
NIXPACKS_NX_APP_NAME=twenty-front

#################
# WORKER SERVICE
#################

# Database URLs (same as backend)
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# NX Configuration
NIXPACKS_NX_APP_NAME=twenty-server

#################
# OPTIONAL CONFIGS
#################

# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn-url

# Analytics  
ANALYTICS_ENABLED=false

# Security
CORS_ORIGIN=https://your-frontend-service.railway.app

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=10485760

# Workspace
DEFAULT_WORKSPACE_NAME=Twenty